{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/agent-orchestrator post-stop --repo $CLAUDE_PROJECT_DIR",
            "timeout": 180,
            "statusMessage": "Running shared post-stop checks..."
          }
        ]
      }
    ]
  }
}
